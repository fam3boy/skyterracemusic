{
  "crons": [
    {
      "path": "/api/cron/weekly-mail",
      "schedule": "0 19 * * 4"
    },
    {
      "path": "/api/cron/cleanup-contacts",
      "schedule": "0 0 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
